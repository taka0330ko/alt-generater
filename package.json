{
  "name": "taka-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:ts": "tsc --project tsconfig.json",
    "build:css": "tailwindcss -i ./src/style.css -o ./dist/style.css --minify",
    "build": "npm run build:ts && npm run build:css",
    "watch:ts": "tsc --project tsconfig.json --watch",
    "watch:css": "tailwindcss -i ./src/style.css -o ./dist/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "tailwindcss": "^4.2.2"
  }
}
